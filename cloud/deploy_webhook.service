[Unit]
Description=Tremplin deploy webhook
After=network.target docker.service
Wants=docker.service

[Service]
ExecStart=/usr/bin/python3 YOUR_INSTALL_DIR/cloud/deploy_webhook.py
EnvironmentFile=YOUR_INSTALL_DIR/cloud/.env
Environment=REPO_DIR=YOUR_INSTALL_DIR
Restart=always
User=YOUR_USER

[Install]
WantedBy=multi-user.target
