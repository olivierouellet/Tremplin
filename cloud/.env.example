# Copy this file to .env and fill in the values before running docker compose.

# Flask secret key — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me

# Admin credentials for /admin
ADMIN_USER=admin
ADMIN_PASSWORD=change_me

# Shared secret for the deploy webhook (powers the Update button in /admin)
# Generated automatically by install.sh
DEPLOY_SECRET=change_me
